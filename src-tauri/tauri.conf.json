{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Open Sim Telemetry",
  "version": "0.1.0",
  "identifier": "com.novent.ost",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OST",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
  "active": true,
  "targets": "all",
  "icon": [  ],
  "android": {
    "debugApplicationIdSuffix": ".debug"
  }
  }
}
