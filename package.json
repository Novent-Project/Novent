		"@types/three": "^0.185.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.3.0",
		"@fontsource-variable/jetbrains-mono": "^5.3.0",
